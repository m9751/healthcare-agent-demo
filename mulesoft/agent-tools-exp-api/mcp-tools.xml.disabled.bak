<?xml version="1.0" encoding="UTF-8"?>
<mule xmlns="http://www.mulesoft.org/schema/mule/core"
  xmlns:doc="http://www.mulesoft.org/schema/mule/documentation"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:http="http://www.mulesoft.org/schema/mule/http"
  xmlns:ee="http://www.mulesoft.org/schema/mule/ee/core"
  xmlns:mcp="http://www.mulesoft.org/schema/mule/mcp"
  xsi:schemaLocation="
    http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
    http://www.mulesoft.org/schema/mule/http http://www.mulesoft.org/schema/mule/http/current/mule-http.xsd
    http://www.mulesoft.org/schema/mule/ee/core http://www.mulesoft.org/schema/mule/ee/core/current/mule-ee.xsd
    http://www.mulesoft.org/schema/mule/mcp http://www.mulesoft.org/schema/mule/mcp/current/mule-mcp.xsd">

  <!-- MCP Server Configuration — Streamable HTTP transport -->
  <mcp:server name="MCP_Server_config" doc:name="MCP Server config"
    serverName="Healthcare Clinical Intelligence" serverVersion="1.0.0">
    <mcp:streamable-http-server listenerConfig="HTTP_Listener_config" mcpEndpointPath="/mcp"/>
  </mcp:server>

  <!-- ============================================================
       MCP TOOL LISTENERS
       Exposes Experience API endpoints as MCP-compatible tools.
       Any MCP client (Agentforce, Claude, GPT) connects via MCP protocol.
       Uses Streamable HTTP transport per MCP Connector v1.3.1.
       ============================================================ -->

  <!-- Tool: listAllPatients -->
  <flow name="mcp-list-all-patients" doc:name="MCP Tool: listAllPatients">
    <mcp:tool-listener config-ref="MCP_Server_config" doc:name="listAllPatients" name="listAllPatients">
      <mcp:description>List all patients from both CareStack and Meditab EHR systems. Returns normalized patient demographics including name, birthDate, gender, address, and source system (CareStack or Meditab).</mcp:description>
      <mcp:parameters-schema><![CDATA[{
        "type": "object",
        "properties": {},
        "required": []
      }]]></mcp:parameters-schema>
    </mcp:tool-listener>
    <http:request config-ref="Clinical_Federation_PRC_API_config" method="GET"
      path="${prcapi.clinical.basePath}/patients" doc:name="GET patients"/>
    <ee:transform doc:name="Format MCP response">
      <ee:message>
        <ee:set-payload><![CDATA[#[output application/json --- payload]]]></ee:set-payload>
      </ee:message>
    </ee:transform>
  </flow>

  <!-- Tool: getPatientConditions -->
  <flow name="mcp-get-patient-conditions" doc:name="MCP Tool: getPatientConditions">
    <mcp:tool-listener config-ref="MCP_Server_config" doc:name="getPatientConditions" name="getPatientConditions">
      <mcp:description>Get all conditions and diagnoses for a specific patient. Returns conditions with ICD-10 codes, display names, and onset dates. Use patient IDs with prefix cs- (CareStack) or mt- (Meditab).</mcp:description>
      <mcp:parameters-schema><![CDATA[{
        "type": "object",
        "properties": {
          "patientId": {
            "type": "string",
            "description": "Patient ID with EHR prefix (e.g., cs-abc12345 for CareStack, mt-def67890 for Meditab)"
          }
        },
        "required": ["patientId"]
      }]]></mcp:parameters-schema>
    </mcp:tool-listener>
    <http:request config-ref="Clinical_Federation_PRC_API_config" method="GET"
      path="${prcapi.clinical.basePath}/patients/{patientId}/conditions" doc:name="GET conditions">
      <http:uri-params><![CDATA[#[output application/java --- { "patientId": payload.patientId }]]]></http:uri-params>
    </http:request>
  </flow>

  <!-- Tool: searchConditions -->
  <flow name="mcp-search-conditions" doc:name="MCP Tool: searchConditions">
    <mcp:tool-listener config-ref="MCP_Server_config" doc:name="searchConditions" name="searchConditions">
      <mcp:description>Search for patients with a specific condition across both EHR systems. Accepts ICD-10 codes (e.g., E11.9 for Type 2 Diabetes) or SNOMED codes. Returns all matching conditions with patient IDs.</mcp:description>
      <mcp:parameters-schema><![CDATA[{
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "ICD-10 or SNOMED condition code (e.g., E11.9 for Type 2 Diabetes, I10 for Hypertension)"
          }
        },
        "required": ["code"]
      }]]></mcp:parameters-schema>
    </mcp:tool-listener>
    <http:request config-ref="Clinical_Federation_PRC_API_config" method="GET"
      path="${prcapi.clinical.basePath}/conditions" doc:name="Search conditions">
      <http:query-params><![CDATA[#[output application/java --- { "code": payload.code }]]]></http:query-params>
    </http:request>
  </flow>

  <!-- Tool: getPatientLabs -->
  <flow name="mcp-get-patient-labs" doc:name="MCP Tool: getPatientLabs">
    <mcp:tool-listener config-ref="MCP_Server_config" doc:name="getPatientLabs" name="getPatientLabs">
      <mcp:description>Get laboratory test results for a specific patient. Returns lab values with LOINC codes, numeric values, units, and dates. Includes blood work like A1c (4548-4), glucose, cholesterol panels.</mcp:description>
      <mcp:parameters-schema><![CDATA[{
        "type": "object",
        "properties": {
          "patientId": {
            "type": "string",
            "description": "Patient ID with EHR prefix (e.g., cs-abc12345 or mt-def67890)"
          }
        },
        "required": ["patientId"]
      }]]></mcp:parameters-schema>
    </mcp:tool-listener>
    <http:request config-ref="Clinical_Federation_PRC_API_config" method="GET"
      path="${prcapi.clinical.basePath}/patients/{patientId}/observations" doc:name="GET labs">
      <http:uri-params><![CDATA[#[output application/java --- { "patientId": payload.patientId }]]]></http:uri-params>
    </http:request>
  </flow>

  <!-- Tool: getPatientMedications -->
  <flow name="mcp-get-patient-medications" doc:name="MCP Tool: getPatientMedications">
    <mcp:tool-listener config-ref="MCP_Server_config" doc:name="getPatientMedications" name="getPatientMedications">
      <mcp:description>Get active medication requests for a specific patient. Returns medication names, RxNorm codes, dosage instructions, status, and date written.</mcp:description>
      <mcp:parameters-schema><![CDATA[{
        "type": "object",
        "properties": {
          "patientId": {
            "type": "string",
            "description": "Patient ID with EHR prefix (e.g., cs-abc12345 or mt-def67890)"
          }
        },
        "required": ["patientId"]
      }]]></mcp:parameters-schema>
    </mcp:tool-listener>
    <http:request config-ref="Clinical_Federation_PRC_API_config" method="GET"
      path="${prcapi.clinical.basePath}/patients/{patientId}/medications" doc:name="GET medications">
      <http:uri-params><![CDATA[#[output application/java --- { "patientId": payload.patientId }]]]></http:uri-params>
    </http:request>
  </flow>

  <!-- Tool: getPatientAllergies -->
  <flow name="mcp-get-patient-allergies" doc:name="MCP Tool: getPatientAllergies">
    <mcp:tool-listener config-ref="MCP_Server_config" doc:name="getPatientAllergies" name="getPatientAllergies">
      <mcp:description>Get allergy and intolerance records for a specific patient. Returns allergen substance, category (food/medication/environment), criticality (low/high), reaction details, and clinical status.</mcp:description>
      <mcp:parameters-schema><![CDATA[{
        "type": "object",
        "properties": {
          "patientId": {
            "type": "string",
            "description": "Patient ID with EHR prefix (e.g., cs-abc12345 or mt-def67890)"
          }
        },
        "required": ["patientId"]
      }]]></mcp:parameters-schema>
    </mcp:tool-listener>
    <http:request config-ref="Clinical_Federation_PRC_API_config" method="GET"
      path="${prcapi.clinical.basePath}/patients/{patientId}/allergies" doc:name="GET allergies">
      <http:uri-params><![CDATA[#[output application/java --- { "patientId": payload.patientId }]]]></http:uri-params>
    </http:request>
  </flow>

  <!-- Tool: discoverFhirServer -->
  <flow name="mcp-discover-servers" doc:name="MCP Tool: discoverFhirServer">
    <mcp:tool-listener config-ref="MCP_Server_config" doc:name="discoverFhirServer" name="discoverFhirServer">
      <mcp:description>Discover connected FHIR R4 EHR servers and their capabilities. Returns server name, FHIR version, software info, and total supported resource types for each connected system.</mcp:description>
      <mcp:parameters-schema><![CDATA[{
        "type": "object",
        "properties": {},
        "required": []
      }]]></mcp:parameters-schema>
    </mcp:tool-listener>
    <http:request config-ref="Clinical_Federation_PRC_API_config" method="GET"
      path="${prcapi.clinical.basePath}/discover" doc:name="GET discover"/>
  </flow>

  <!-- Tool: healthCheck -->
  <flow name="mcp-health-check" doc:name="MCP Tool: healthCheck">
    <mcp:tool-listener config-ref="MCP_Server_config" doc:name="healthCheck" name="healthCheck">
      <mcp:description>Check the health status of the Healthcare Clinical Intelligence API and all downstream dependencies.</mcp:description>
      <mcp:parameters-schema><![CDATA[{
        "type": "object",
        "properties": {},
        "required": []
      }]]></mcp:parameters-schema>
    </mcp:tool-listener>
    <ee:transform doc:name="Health response">
      <ee:message>
        <ee:set-payload><![CDATA[#[output application/json --- {
          status: "healthy",
          api: "Healthcare Clinical Intelligence MCP Server",
          version: "1.0.0",
          tools: 8,
          transport: "Streamable HTTP"
        }]]]></ee:set-payload>
      </ee:message>
    </ee:transform>
  </flow>

</mule>
